<%- include('../partials/head') %>
  <body class="bg-gray-100">
    <%- include('../partials/nav') %>
    <main class="container mx-auto mt-8 max-w-xl px-4">
      <section class="rounded-3xl border border-red-100 bg-white p-8 shadow-xl shadow-red-100/60">
      <h1 class="mb-6 text-center text-3xl font-bold text-gray-800">Login with your info</h1>
      <form action="/login" method="POST" class="max-w-md mx-auto">
        <%- include('../partials/errors') %>
        <input
          type="email"
          name="email"
          value="<%= oldInput?.email ? oldInput.email : '' %>"
          placeholder="Enter your email"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"
          required />
        <input
          type="password"
          name="password"
          placeholder="Enter Your Password"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"
          required/>
        <input type="submit" value="Sign In" class="w-full rounded-md bg-red-500 py-2 text-white transition duration-300 hover:bg-red-600" />
        <p class="mt-4 text-center text-gray-600">
          Don&apos;t have an account? <a href="/signup" class="text-red-500 hover:underline">Create one</a>
        </p>
      </form>
      </section>
    </main>
  </body>
</html>
